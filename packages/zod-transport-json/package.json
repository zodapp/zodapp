{
  "name": "@zodapp/zod-transport-json",
  "version": "0.0.0",
  "private": false,
  "description": "JSON transport helpers for Zod schemas",
  "author": "zodapp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zodapp/zodapp.git",
    "directory": "packages/zod-transport-json"
  },
  "homepage": "https://github.com/zodapp/zodapp#readme",
  "bugs": {
    "url": "https://github.com/zodapp/zodapp/issues"
  },
  "keywords": [
    "zod",
    "json",
    "transport"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "test": "vitest run",
    "lint": "eslint .",
    "build": "tsup",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist .turbo node_modules",
    "docs:typedoc": "node ../../tools/gen-typedoc.mjs"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.7",
    "eslint": "^9.34.0",
    "rimraf": "^6.1.2",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@zodapp/zod-transform": "workspace:*",
    "dayjs": "^1.11.20",
    "zod": "^4.4.3"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
