{
  "name": "@zodapp/react-storage",
  "version": "0.0.0",
  "private": false,
  "description": "React hooks for browser-backed storage state",
  "author": "zodapp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zodapp/zodapp.git",
    "directory": "packages/react-storage"
  },
  "homepage": "https://github.com/zodapp/zodapp#readme",
  "bugs": {
    "url": "https://github.com/zodapp/zodapp/issues"
  },
  "keywords": [
    "react",
    "storage",
    "browser"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "rimraf dist && tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint .",
    "lint:silent": "mkdir -p output && pnpm lint > ./output/lint.txt",
    "clean": "rimraf dist .turbo node_modules",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "docs:typedoc": "node ../../tools/gen-typedoc.mjs"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.3",
    "eslint": "^9.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
