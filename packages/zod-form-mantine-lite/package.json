{
  "name": "@zodapp/zod-form-mantine-lite",
  "version": "0.0.0",
  "private": false,
  "description": "Mantine UI components for zod-form (TanStack-free)",
  "author": "zodapp",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zodapp/zodapp.git",
    "directory": "packages/zod-form-mantine-lite"
  },
  "homepage": "https://github.com/zodapp/zodapp#readme",
  "bugs": {
    "url": "https://github.com/zodapp/zodapp/issues"
  },
  "keywords": [
    "zod",
    "form",
    "mantine",
    "react",
    "ui"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": ["*.css"],
  "exports": {
    ".": "./src/index.ts",
    "./baseComponents": "./src/baseComponents/index.ts",
    "./baseComponents/*": "./src/baseComponents/*.tsx",
    "./tableComponents": "./src/tableComponents/index.ts",
    "./tableComponents/*": "./src/tableComponents/*.tsx",
    "./reactiveComponents": "./src/reactiveComponents/index.ts",
    "./reactiveComponents/*": "./src/reactiveComponents/*.tsx",
    "./mediaResolvers": "./src/mediaResolvers/index.ts",
    "./utils": "./src/utils/index.ts",
    "./utils/*": "./src/utils/*"
  },
  "scripts": {
    "lint": "eslint .",
    "build": "rimraf dist && tsc",
    "check-types": "tsc --noEmit",
    "clean": "rimraf dist .turbo node_modules",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --watch",
    "docs:typedoc": "node ../../tools/gen-typedoc.mjs"
  },
  "devDependencies": {
    "@mantine/dates": "^8.3.14",
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.19.7",
    "@types/react": "^19.2.3",
    "@types/react-is": "^19.2.0",
    "eslint": "^9.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.2",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.36.1",
    "@zodapp/zod-form": "workspace:*",
    "@zodapp/zod-form-react": "workspace:*",
    "dayjs": "^1.11.19",
    "react-is": "^19.2.4",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@mantine/core": "^8.2.7",
    "@mantine/dates": "^8.2.7",
    "@mantine/hooks": "^8.2.7",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "volta": {
    "extends": "../../package.json"
  }
}
